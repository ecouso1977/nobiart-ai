# SenGuard Backend — Environment Variables
# Copy this to .env and fill in your values
# In production, use GCP Secret Manager (see DEPLOYMENT.md)

MONGO_URL="mongodb+srv://USER:PASS@cluster.mongodb.net/senguard_db?retryWrites=true&w=majority"
DB_NAME="senguard_db"
CORS_ORIGINS="*"
JWT_SECRET="your-jwt-secret-min-32-chars"
GEMINI_API_KEY="your-google-gemini-api-key"
GOOGLE_API_KEY="your-google-gemini-api-key"
EMERGENT_LLM_KEY="your-emergent-llm-key"
GCS_BUCKET_NAME="your-gcs-bucket-name"
FRONTEND_URL="http://localhost:3000"
ADMIN_EMAIL="admin@senguard.com"
ADMIN_PASSWORD="YourSecurePassword!"
